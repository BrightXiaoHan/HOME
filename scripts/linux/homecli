#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
	SOURCE_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
	SOURCE="$(readlink "$SOURCE")"
	[[ "$SOURCE" != /* ]] && SOURCE="$SOURCE_DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"

usage() {
	cat <<'EOF'
Usage: homecli <command> [args...]

Commands:
  install       Install HOME environment
  update        Update HOME environment and installed components
  uninstall     Uninstall HOME environment
  relink        Recreate configuration links for an existing install
  pack          Pack current installation into a self-extracting installer
  test          Validate an installation
  components    Install or update Linux components
  bash          Enter isolated bash environment (for agents/scripts)
  fish          Enter isolated fish environment (interactive)

Examples:
  homecli install --install-dir "$HOME/.homecli"
  homecli relink --install-dir "$HOME/.homecli"
  homecli components update
  homecli test --configs --nvim
EOF
}

if [ -n "${HOMECLI_INSTALL_DIR:-}" ]; then
	INSTALL_DIR=$HOMECLI_INSTALL_DIR
else
	INSTALL_DIR_CANDIDATE="$(cd "$SCRIPT_DIR/../../.." >/dev/null 2>&1 && pwd)"
	if [ -d "$INSTALL_DIR_CANDIDATE/HOME" ] || [ -x "$INSTALL_DIR_CANDIDATE/bin/homecli-bash" ]; then
		INSTALL_DIR=$INSTALL_DIR_CANDIDATE
	else
		INSTALL_DIR=$HOME/.homecli
	fi
fi

command=${1:-}
if [ -z "$command" ]; then
	usage
	exit 1
fi
shift || true

case "$command" in
install)
	exec "$SCRIPT_DIR/install.sh" "$@"
	;;
update)
	exec "$SCRIPT_DIR/update.sh" "$@"
	;;
uninstall)
	exec "$SCRIPT_DIR/uninstall.sh" "$@"
	;;
relink)
	exec "$SCRIPT_DIR/install.sh" --mode relink "$@"
	;;
pack)
	exec "$SCRIPT_DIR/pack.sh" "$@"
	;;
test)
	exec "$SCRIPT_DIR/test.sh" "$@"
	;;
components | component)
	exec "$SCRIPT_DIR/components.sh" "$@"
	;;
bash)
	exec "$INSTALL_DIR/bin/homecli-bash" "$@"
	;;
fish)
	exec "$INSTALL_DIR/bin/homecli-fish" "$@"
	;;
-h | --help | help)
	usage
	;;
*)
	echo "Unknown command: $command" >&2
	usage >&2
	exit 1
	;;
esac
